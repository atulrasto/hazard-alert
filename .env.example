# Polling interval
CHECK_INTERVAL_SECONDS=300

# Delhi/NCR negative news alerts
NEWS_ENABLED=true
# Leave blank to use default Delhi feeds from Hindustan Times, Indian Express, and Google News search.
NEWS_RSS_URLS=
NEWS_NEGATIVE_KEYWORDS=accident,attack,blast,bomb,collapse,crime,curfew,danger,death,disease,epidemic,evacuation,explosion,fire,flood,heavy rain,kidnap,murder,outbreak,panic,protest,riot,shooting,stampede,terror,threat,toxic,violence,waterlogging

# Email notifications
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_sender_login@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=first@example.com,second@example.com
EMAIL_SENDER_NAME=Hazard Alert

# Backup email account used if the primary sender fails
BACKUP_EMAIL_USERNAME=
BACKUP_EMAIL_PASSWORD=
BACKUP_EMAIL_SMTP_HOST=smtp.gmail.com
BACKUP_EMAIL_SMTP_PORT=587
